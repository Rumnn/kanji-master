# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://127.0.0.1:27017/kanji_master
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/kanji_master?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/kanji_master

# JWT Secret (change this in production!)
JWT_SECRET=super_secret_kanji_key_12345
